# ==========================================
# Plantation GIS - Master Environment Config
# ==========================================

# --- Backend Configuration ---
POSTGRES_USER=plantation_user
POSTGRES_PASSWORD=plantation_pass
POSTGRES_DB=plantation
DATABASE_URL=postgresql://plantation_user:plantation_pass@postgres:5432/plantation
REDIS_URL=redis://localhost:6379/0
JWT_SECRET=plantation-jwt-secret-change-in-prod
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# --- Storage Paths (Local defaults) ---
UPLOAD_DIR=./backend/uploads
TILES_DIR=./backend/tiles

# --- Vision & AI ---
NODEODM_URL=http://localhost:3000
YOLO_MODEL_PATH=./backend/models/yolov9_trees.onnx

# --- Frontend Configuration ---
VITE_API_URL=http://localhost:8000
